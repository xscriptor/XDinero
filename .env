# Configuración del entorno para XDinero (DESARROLLO LOCAL)
# Este archivo es para desarrollo local directo y es nada más que un ejemplo

#  Base de Datos (MySQL) 
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=xdinero_db
MYSQL_USER=xdinero_user
MYSQL_PASSWORD=xdinero_password
DB_HOST=db

#  Proxy (Nginx) 
# Puerto público principal (normalmente 80)
PROXY_PORT=80

#  Backend (PHP) 
# Puerto expuesto en el host para el backend (SOLO LOCALHOST en la nueva config)
BACKEND_PORT=8000

#  Frontend (Next.js) 
# Puerto expuesto en el host para el frontend (SOLO LOCALHOST en la nueva config)
FRONTEND_PORT=3000

# URLs de la API para el frontend
#
# SI USAS EL PROXY (Recomendado en producción):
# La URL debe apuntar al dominio principal o IP del servidor, sin puerto 8000.
# Ejemplo Local con Proxy: http://localhost/backend/api
# Ejemplo Producción: https://tu-dominio.com/backend/api
#
# SI USAS PUERTOS DIRECTOS (Desarrollo sin proxy):
# http://localhost:8000/backend/api
NEXT_PUBLIC_API_URL=http://localhost:8000/backend/api

# URL base para recursos estáticos (imágenes)
# Ejemplo Local con Proxy: http://localhost/backend
# Ejemplo Producción: https://tu-dominio.com/backend
NEXT_PUBLIC_BASE_URL=http://localhost:8000/backend
